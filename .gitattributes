# Normalize line endings: store text as LF in the repo regardless of OS.
* text=auto eol=lf

# Shell scripts must stay LF even on Windows checkouts (they run in Linux containers).
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Treat binary assets as binary (no diff / no EOL conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.jar binary
